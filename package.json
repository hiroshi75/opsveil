{
  "name": "opsveil",
  "private": true,
  "version": "0.1.0",
  "description": "AgentBoard - Agent Command Center IDE",
  "scripts": {
    "dev:server": "pnpm --filter @opsveil/server dev",
    "dev:client": "pnpm --filter @opsveil/client dev",
    "build:shared": "pnpm --filter @opsveil/shared build",
    "build:server": "pnpm --filter @opsveil/server build",
    "build:client": "pnpm --filter @opsveil/client build",
    "build": "pnpm build:shared && pnpm build:server && pnpm build:client",
    "dev": "pnpm build:shared && concurrently \"pnpm dev:server\" \"pnpm dev:client\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
